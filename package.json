{
	"name": "pandorha-engine",
	"version": "0.5.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite --host 127.0.0.1",
		"build": "vite build",
		"preview": "vite preview --host 127.0.0.1",
		"db:generate": "drizzle-kit generate --config=drizzle.config.mjs",
		"db:migration:test": "vitest run src/entities/character/__tests__/CharacterMigration.spec.ts",
		"test": "vitest run",
		"test:mutation": "stryker run",
		"test:unit": "vitest run",
		"test:coverage": "vitest run --coverage.enabled true --coverage.reporter=json-summary",
		"test:mechanics": "python .agents/skills/rpg-mechanics-validator/scripts/simulate_mechanics.py",
		"lint": "biome check --diagnostic-level=error biome.json drizzle.config.mjs index.html src package.json tsconfig.json vite.config.mjs vitest.config.mjs scripts/install_process_hooks.mjs scripts/process_hook_runner.mjs scripts/run_full_quality_gate.mjs scripts/scaffold_catalog_entity.mjs scripts/test_scaffold_catalog_entity.mjs scripts/scaffold_domain_service.mjs scripts/test_scaffold_domain_service.mjs scripts/validate_coverage_registration.mjs scripts/test_validate_coverage_registration.mjs scripts/test_skill_validators.mjs .agents/skills/core-conventions/scripts/validate.mjs .agents/skills/self-review-checklist/scripts/hard_stop.mjs .agents/skills/self-review-checklist/scripts/run_json_tests.mjs && tsc --noEmit",
		"quality:gate": "node scripts/run_full_quality_gate.mjs",
		"quality:root": "node scripts/run_full_quality_gate.mjs --only=root",
		"quality:mcp": "node scripts/run_full_quality_gate.mjs --only=mcp",
		"quality:skills": "node scripts/run_full_quality_gate.mjs --only=skills",
		"quality:automation": "node scripts/run_full_quality_gate.mjs --only=automation",
		"quality:release": "node scripts/run_full_quality_gate.mjs --only=release",
		"automation:doctor": "python scripts/pandorha_process_automation.py validate",
		"automation:hooks": "node scripts/install_process_hooks.mjs",
		"scaffold:catalog-entity": "node scripts/scaffold_catalog_entity.mjs",
		"scaffold:domain-service": "node scripts/scaffold_domain_service.mjs"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^22.15.3",
		"@types/sql.js": "^1.4.11",
		"@vitest/coverage-v8": "^4.1.8",
		"drizzle-kit": "^0.31.10",
		"fast-check": "^4.8.0",
		"happy-dom": "^20.10.2",
		"sql.js": "^1.14.1",
		"svelte": "^5.55.5",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.8.3",
		"vite": "^7.3.2",
		"vitest": "^4.1.8"
	},
	"overrides": {
		"esbuild": "^0.28.1"
	}
}
