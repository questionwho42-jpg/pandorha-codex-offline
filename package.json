{
	"name": "pandorha-engine",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite --host 127.0.0.1",
		"build": "vite build",
		"preview": "vite preview --host 127.0.0.1",
		"db:generate": "drizzle-kit generate --config=drizzle.config.mjs",
		"db:migration:test": "vitest run src/entities/character/__tests__/CharacterMigration.spec.ts",
		"test": "vitest run",
		"test:unit": "vitest run",
		"test:coverage": "vitest run --coverage.enabled true --coverage.reporter=json-summary",
		"lint": "biome check biome.json drizzle.config.mjs index.html src package.json tsconfig.json vite.config.mjs vitest.config.mjs scripts/run_full_quality_gate.mjs && tsc --noEmit",
		"quality:gate": "node scripts/run_full_quality_gate.mjs",
		"quality:root": "node scripts/run_full_quality_gate.mjs --only=root",
		"quality:mcp": "node scripts/run_full_quality_gate.mjs --only=mcp",
		"quality:skills": "node scripts/run_full_quality_gate.mjs --only=skills"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^22.15.3",
		"@types/sql.js": "^1.4.11",
		"@vitest/coverage-v8": "^3.2.4",
		"drizzle-kit": "^0.31.10",
		"sql.js": "^1.14.1",
		"svelte": "^5.55.5",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.8.3",
		"vite": "^7.3.2",
		"vitest": "^3.2.4"
	}
}
