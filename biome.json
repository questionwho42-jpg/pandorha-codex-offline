{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"files": {
		"includes": [
			"**",
			"!**/CraftingService.spec.ts",
			"!**/RepairService.spec.ts",
			"!**/EspionageService.spec.ts",
			"!**/ResearchService.spec.ts"
		]
	},
	"linter": {
		"rules": {
			"style": {
				"noNonNullAssertion": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
